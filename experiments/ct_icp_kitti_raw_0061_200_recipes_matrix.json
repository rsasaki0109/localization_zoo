{
  "schema_version": 1,
  "problem": {
    "id": "ct_icp_kitti_raw_0061_200_recipes",
    "title": "CT-ICP cluster A/D bake-off on KITTI Raw 0061 200-frame short window",
    "question": "0061_full became a cluster D winner (ms_chol 4.50 m, -35% vs fast). The 200-frame variant has fast_window 1.48 m winning. Does cluster D dethrone fast on the short window too, or is short-window 0061 different?",
    "dataset": {
      "pcd_dir": "dogfooding_results/kitti_raw_0061_200",
      "gt_csv": "experiments/reference_data/kitti_raw_0061_200_gt.csv"
    },
    "same_metrics": ["ate_m", "fps", "rpe_trans_pct", "readability_score", "extensibility_score"]
  },
  "stable_interface": {
    "binary": "build/evaluation/pcd_dogfooding",
    "methods": "ct_icp",
    "primary_method": "CT-ICP"
  },
  "variants": [
    {
      "id": "fast_reference",
      "label": "fast_window (current best 1.48 m)",
      "design_style": "reference",
      "intent": "Confirm baseline.",
      "args": ["--ct-icp-fast-profile"]
    },
    {
      "id": "cluster_a",
      "label": "cluster A (map=50 + c2f σ×2)",
      "design_style": "long-traj-recipe",
      "intent": "Cluster A on 200-frame raw.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "50", "--ct-icp-coarse-to-fine", "--ct-icp-coarse-iterations", "2", "--ct-icp-coarse-search-radius", "2", "--ct-icp-coarse-cauchy-mult", "2.0", "--ct-icp-coarse-planarity-threshold", "0.06"]
    },
    {
      "id": "cluster_d_ms_chol",
      "label": "cluster D (ms_chol)",
      "design_style": "short-traj-recipe",
      "intent": "ms_chol on 200-frame raw — extends 0061_full cluster D win?",
      "args": ["--ct-icp-dense-profile", "--ct-icp-multi-scale", "--ct-icp-normal-cholesky"]
    }
  ]
}
