    },
    {
      "id": "corr_8",
      "label": "arch_tuned corr=8",
      "design_style": "looser",
      "intent": "seq 00/02 winner threshold.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "8", "--ct-icp-max-frames-in-map", "30", "--ct-icp-max-correspondence-distance", "8.0", "--ct-icp-keypoint-voxel-size", "0.5"]
    },
    {
      "id": "corr_16",
      "label": "arch_tuned corr=16",
      "design_style": "much looser",
      "intent": "Test broader regime.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "8", "--ct-icp-max-frames-in-map", "30", "--ct-icp-max-correspondence-distance", "16.0", "--ct-icp-keypoint-voxel-size", "0.5"]
