{
  "schema_version": 1,
  "problem": {
    "id": "litamin2_kitti_seq_00_full_tuned_seeded",
    "title": "LiTAMIN2 tuned knobs (voxel=1.0, iter=12) on KITTI seq 00 full with GT seed",
    "question": "Tuned no-seed gave RPE 0.92% (best on seq 00) but ATE 13.46 m due to no-seed drift. fast+seed gave ATE 0.998 m but RPE 1.91%. Combining (voxel=1.0 + iter=12) + seed — does this give both <1 m ATE and <1% RPE?",
    "dataset": {
      "pcd_dir": "dogfooding_results/kitti_seq_00_full",
      "gt_csv": "experiments/reference_data/kitti_seq_00_full_gt.csv"
    },
    "same_metrics": ["ate_m", "fps", "rpe_trans_pct", "readability_score", "extensibility_score"]
  },
  "stable_interface": {
    "binary": "build/evaluation/pcd_dogfooding",
    "methods": "litamin2",
    "primary_method": "LiTAMIN2"
  },
  "variants": [
    {
      "id": "tuned_voxel1_iter12_seeded",
      "label": "voxel=1.0 + iter=12 + GT seed",
      "design_style": "tuned-seeded",
      "intent": "Combine tightest known knobs with seed — does it dethrone fast+seed 0.998 m?",
      "args": ["--litamin2-voxel-resolution", "1.0", "--litamin2-max-iterations", "12"]
    },
    {
      "id": "tuned_voxel0_5_iter12_seeded",
      "label": "voxel=0.5 + iter=12 + GT seed",
      "design_style": "tighter",
      "intent": "Push voxel finer.",
      "args": ["--litamin2-voxel-resolution", "0.5", "--litamin2-max-iterations", "12"]
    },
    {
      "id": "tuned_voxel2_iter12_seeded",
      "label": "voxel=2.0 + iter=12 + GT seed",
      "design_style": "midpoint",
      "intent": "Test voxel midpoint between fast default (auto) and tuned 1.0.",
      "args": ["--litamin2-voxel-resolution", "2.0", "--litamin2-max-iterations", "12"]
    },
    {
      "id": "tuned_voxel1_iter20_seeded",
      "label": "voxel=1.0 + iter=20 + GT seed",
      "design_style": "more-iter",
