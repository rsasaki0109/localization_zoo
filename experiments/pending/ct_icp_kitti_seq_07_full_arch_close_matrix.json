{
  "schema_version": 1,
  "problem": {
    "id": "ct_icp_arch_close_kitti_seq_07_full",
    "title": "CT-ICP architecture-level tuning on KITTI Odometry 07 (full)",
    "question": "Do tighter max_correspondence_dist, lower keypoint_voxel_size, higher planarity_threshold, larger ceres budget close more than the 4.5x parameter ceiling?",
    "dataset": {
      "pcd_dir": "dogfooding_results/kitti_seq_07_full",
      "gt_csv": "experiments/reference_data/kitti_seq_07_full_gt.csv"
    },
    "same_metrics": ["ate_m", "fps", "rpe_trans_pct", "readability_score", "extensibility_score"]
  },
  "stable_interface": {
    "binary": "build/evaluation/pcd_dogfooding",
    "methods": "ct_icp",
    "primary_method": "CT-ICP"
  },
  "variants": [
    {
      "id": "prior_best",
      "label": "Prior best (dense + ceres 6 + map 20)",
      "design_style": "reference",
      "intent": "Reference: tuned-v1 winner from d81dba7.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20"]
    },
    {
      "id": "tighter_max_corr",
      "label": "dense + ceres 6 + max_corr 2.0",
      "design_style": "tighter correspondence",
      "intent": "Tighten outlier rejection (default 100 m^2 = 10m linear, paper 1-2 m^2).",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20", "--ct-icp-max-correspondence-distance", "2.0"]
    },
    {
      "id": "max_corr_4",
      "label": "dense + ceres 6 + max_corr 4.0",
      "design_style": "moderate tight",
      "intent": "Halfway between 100 m^2 and 2 m^2.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20", "--ct-icp-max-correspondence-distance", "4.0"]
    },
    {
      "id": "smaller_keypoint",
      "label": "dense + smaller keypoint voxel 0.5",
      "design_style": "more keypoints",
      "intent": "Halve keypoint voxel to keep more keypoints per scan.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20", "--ct-icp-keypoint-voxel-size", "0.5"]
    },
    {
      "id": "high_planarity",
      "label": "dense + planarity 0.5",
      "design_style": "strict planar features",
      "intent": "Require strongly planar features (paper-style strict threshold).",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20", "--ct-icp-planarity-threshold", "0.5"]
    },
    {
      "id": "all_combined",
      "label": "dense + max_corr 4.0 + keypoint 0.5 + ceres 8 + map 30",
      "design_style": "all-in",
      "intent": "Apply all promising knobs together.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "8", "--ct-icp-max-frames-in-map", "30", "--ct-icp-max-correspondence-distance", "4.0", "--ct-icp-keypoint-voxel-size", "0.5"]
    }
  ]
