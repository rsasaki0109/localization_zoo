{
  "schema_version": 1,
  "problem": {
    "id": "ct_icp_paper_arch_kitti_seq_07_full",
    "title": "CT-ICP paper-arch (gate + multi-scale + DENSE_NORMAL_CHOLESKY) on KITTI Odometry 07 (full)",
    "question": "Do refinement-gate, multi-scale findCorrespondences, and DENSE_NORMAL_CHOLESKY solver close the residual gap below the 4.5x parameter ceiling?",
    "dataset": {
      "pcd_dir": "dogfooding_results/kitti_seq_07_full",
      "gt_csv": "experiments/reference_data/kitti_seq_07_full_gt.csv"
    },
    "same_metrics": ["ate_m", "fps", "rpe_trans_pct", "readability_score", "extensibility_score"]
  },
  "stable_interface": {
    "binary": "build/evaluation/pcd_dogfooding",
    "methods": "ct_icp",
    "primary_method": "CT-ICP"
  },
  "variants": [
    {
      "id": "prior_best_tunev1",
      "label": "tune-v1 baseline (dense + ceres 6 + map 20)",
      "design_style": "reference",
      "intent": "Baseline against which arch-level features are measured.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20"]
    },
    {
      "id": "gate_only",
      "label": "tune-v1 + refinement-gate (velocity-model bootstrap)",
      "design_style": "gate only",
      "intent": "Isolate gate contribution.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20", "--ct-icp-refinement-gate"]
    },
    {
      "id": "multi_scale_only",
      "label": "tune-v1 + multi-scale findCorrespondences",
      "design_style": "multi-scale only",
      "intent": "Isolate multi-scale contribution.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20", "--ct-icp-multi-scale"]
    },
    {
      "id": "normal_cholesky_only",
      "label": "tune-v1 + DENSE_NORMAL_CHOLESKY",
      "design_style": "cholesky only",
      "intent": "Isolate solver contribution.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20", "--ct-icp-normal-cholesky"]
    },
    {
      "id": "paper_arch_all",
      "label": "tune-v1 + paper-arch bundle (all three)",
      "design_style": "all three",
      "intent": "Apply all architecture-level paper-alignment features.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20", "--ct-icp-paper-arch"]
    },
    {
      "id": "paper_arch_loose_gate",
      "label": "paper-arch with loose gate (3m, 0.4 rad)",
      "design_style": "all three + loose gate",
      "intent": "Reduce false-positive rollbacks by widening gate.",
      "args": ["--ct-icp-dense-profile", "--ct-icp-ceres-max-iterations", "6", "--ct-icp-max-frames-in-map", "20", "--ct-icp-paper-arch", "--ct-icp-max-seed-translation-delta", "3.0", "--ct-icp-max-seed-rotation-delta-rad", "0.4"]
    }
  ]
}
