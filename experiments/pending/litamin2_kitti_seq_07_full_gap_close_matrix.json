{
  "schema_version": 1,
  "problem": {
    "id": "litamin2_gap_close_kitti_seq_07_full",
    "title": "LiTAMIN2 gap-closing on KITTI Odometry 07 (full)",
    "question": "Can increasing max_iterations / decreasing voxel resolution close the 1.7x gap to paper RPE 0.42% on KITTI 07?",
    "dataset": {
      "pcd_dir": "dogfooding_results/kitti_seq_07_full",
      "gt_csv": "experiments/reference_data/kitti_seq_07_full_gt.csv"
    },
    "same_metrics": ["ate_m", "fps", "rpe_trans_pct", "readability_score", "extensibility_score"]
  },
  "stable_interface": {
    "binary": "build/evaluation/pcd_dogfooding",
    "methods": "litamin2",
    "primary_method": "LiTAMIN2"
  },
  "variants": [
    {
      "id": "baseline_fast",
      "label": "Baseline fast (8616c27, RPE 0.72%)",
      "design_style": "baseline",
      "intent": "Reference point: existing fast profile pure-odometry.",
      "args": ["--no-gt-seed"]
    },
    {
      "id": "iter12",
      "label": "max_iterations 12",
      "design_style": "iteration-budget",
      "intent": "Doubled inner-loop iterations.",
      "args": ["--no-gt-seed", "--litamin2-max-iterations", "12"]
    },
    {
      "id": "voxel1_iter12",
      "label": "voxel 1.0 + iter 12",
      "design_style": "finer-voxel + more-iter",
      "intent": "Finer voxel grid and more iterations.",
      "args": ["--no-gt-seed", "--litamin2-voxel-resolution", "1.0", "--litamin2-max-iterations", "12"]
    },
    {
      "id": "voxel15_iter10",
      "label": "voxel 1.5 + iter 10",
      "design_style": "moderate-finer + moderate-more",
      "intent": "Halfway between baseline and aggressive tuning.",
      "args": ["--no-gt-seed", "--litamin2-voxel-resolution", "1.5", "--litamin2-max-iterations", "10"]
    }
  ]
}
